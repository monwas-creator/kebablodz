{
  "name": "kebablodz",
  "version": "1.0.0",
  "description": "Professional online ordering system for Bafra Kebab Łódź",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,md}\"",
    "type-check": "tsc --noEmit",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "ts-node prisma/seed.ts",
    "docker:build": "docker build -f docker/Dockerfile -t kebablodz:latest .",
    "docker:run": "docker-compose -f docker/docker-compose.yml up"
  },
  "dependencies": {
    "next": "^15.1.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.6.3",
    "@prisma/client": "^6.2.0",
    "next-auth": "^5.0.0-beta.32",
    "@auth/prisma-adapter": "^2.2.4",
    "bcryptjs": "^2.4.3",
    "zod": "^3.23.8",
    "react-hook-form": "^7.53.1",
    "@hookform/resolvers": "^3.4.2",
    "framer-motion": "^11.11.1",
    "tailwindcss": "^3.4.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.4.0",
    "resend": "^4.0.1",
    "axios": "^1.7.7",
    "date-fns": "^3.6.0",
    "zustand": "^4.5.2",
    "react-hot-toast": "^2.4.1",
    "next-themes": "^0.2.1",
    "google-map-react": "^2.20.0",
    "class-variance-authority": "^0.7.0",
    "lucide-react": "^0.344.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.11",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@tailwindcss/forms": "^0.5.9",
    "@tailwindcss/typography": "^0.5.15",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.40",
    "prettier": "^3.3.3",
    "eslint": "^9.8.0",
    "eslint-config-next": "^15.1.3",
    "@typescript-eslint/eslint-plugin": "^8.5.0",
    "@typescript-eslint/parser": "^8.5.0",
    "prisma": "^6.2.0",
    "ts-node": "^10.9.2",
    "@types/bcryptjs": "^2.4.6"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
